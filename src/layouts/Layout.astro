---
import '../styles/global.css';

export interface Props {
  title: string;
}

const { title } = Astro.props as Props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta
      name="viewport"
      content="width=device-width"
    />
    <title>{title}</title>
  </head>
  <body class="p-4 font-sans">
    <slot />
  </body>
</html>
